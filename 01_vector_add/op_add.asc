/**
 * @file op_add.asc
 * @brief [Vector-Only] 算子1: 向量加法  C = A + B
 *
 * 类别: 纯Vector核心 — 只调用昇腾NPU的向量计算单元
 * API:  AscendC::Add
 * 内核声明: __global__ __vector__
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "../common/data_utils.h"

constexpr uint32_t NUM_BLOCKS = 8;
constexpr uint32_t SINGLE_CORE_LEN = 4096 * 9;
constexpr uint32_t TILE_LENGTH = 4096;
constexpr uint32_t DATA_LEN = SINGLE_CORE_LEN * NUM_BLOCKS;   // 294912 elements
constexpr uint32_t LOOP_COUNT = SINGLE_CORE_LEN / TILE_LENGTH; // 9

class KernelAdd {
public:
    __aicore__ inline KernelAdd() = default;

    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR c)
    {
        uint32_t offset = AscendC::GetBlockIdx() * SINGLE_CORE_LEN;
        aGm.SetGlobalBuffer((__gm__ float *)a + offset, SINGLE_CORE_LEN);
        bGm.SetGlobalBuffer((__gm__ float *)b + offset, SINGLE_CORE_LEN);
        cGm.SetGlobalBuffer((__gm__ float *)c + offset, SINGLE_CORE_LEN);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAlloc;

        AscendC::LocalTensor<float> aPing = ubAlloc.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> bPing = ubAlloc.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> cPing = ubAlloc.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> aPong = ubAlloc.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> bPong = ubAlloc.Alloc<float, TILE_LENGTH>();
        AscendC::LocalTensor<float> cPong = ubAlloc.Alloc<float, TILE_LENGTH>();

        AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID1);

        for (uint32_t i = 0; i < LOOP_COUNT; i++) {
            int32_t evt = (i % 2 == 0) ? EVENT_ID0 : EVENT_ID1;
            auto &aL = (i % 2 == 0) ? aPing : aPong;
            auto &bL = (i % 2 == 0) ? bPing : bPong;
            auto &cL = (i % 2 == 0) ? cPing : cPong;

            AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(evt);
            AscendC::DataCopy(aL, aGm[i * TILE_LENGTH], TILE_LENGTH);
            AscendC::DataCopy(bL, bGm[i * TILE_LENGTH], TILE_LENGTH);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(evt);

            AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(evt);
            AscendC::Add(cL, aL, bL, TILE_LENGTH);
            AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(evt);

            AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(evt);
            AscendC::DataCopy(cGm[i * TILE_LENGTH], cL, TILE_LENGTH);
            AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(evt);
        }
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID1);
    }

private:
    AscendC::GlobalTensor<float> aGm, bGm, cGm;
};

extern "C" __global__ __vector__ void add_kernel(GM_ADDR a, GM_ADDR b, GM_ADDR c)
{
    AscendC::InitSocState();
    KernelAdd op;
    op.Init(a, b, c);
    op.Process();
}

int main()
{
    size_t byteSize = DATA_LEN * sizeof(float);

    // ACL init
    aclInit(nullptr);
    aclrtSetDevice(0);
    aclrtStream stream;
    aclrtCreateStream(&stream);

    // Alloc & copy inputs
    float *aHost, *bHost, *cHost;
    void *aDev, *bDev, *cDev;
    aclrtMallocHost((void**)&aHost, byteSize);
    aclrtMallocHost((void**)&bHost, byteSize);
    aclrtMallocHost((void**)&cHost, byteSize);
    aclrtMalloc(&aDev, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&bDev, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&cDev, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    size_t fileSize;
    ReadFile("../data/input_a.bin", fileSize, aHost, byteSize);
    ReadFile("../data/input_b.bin", fileSize, bHost, byteSize);
    aclrtMemcpy(aDev, byteSize, aHost, byteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(bDev, byteSize, bHost, byteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // Warmup
    add_kernel<<<NUM_BLOCKS, nullptr, stream>>>(aDev, bDev, cDev);
    aclrtSynchronizeStream(stream);

    // Timed run
    double t0 = GetTimeUs();
    add_kernel<<<NUM_BLOCKS, nullptr, stream>>>(aDev, bDev, cDev);
    aclrtSynchronizeStream(stream);
    double t1 = GetTimeUs();

    // Copy result back
    aclrtMemcpy(cHost, byteSize, cDev, byteSize, ACL_MEMCPY_DEVICE_TO_HOST);

    // CPU golden & verify
    INFO_LOG("========== VectorAdd ==========");
    INFO_LOG("Data size: %u floats (%.2f MB)", DATA_LEN, byteSize / 1024.0 / 1024.0);
    INFO_LOG("Kernel time: %.2f us", t1 - t0);
    double bw = (3.0 * byteSize) / ((t1 - t0) * 1e-6) / 1e9;
    INFO_LOG("Bandwidth:   %.2f GB/s (read A+B + write C)", bw);

    for (uint32_t i = 0; i < DATA_LEN; i++) {
        bHost[i] = aHost[i] + bHost[i]; // reuse bHost as golden
    }
    bool ok = VerifyResult(cHost, bHost, DATA_LEN);

    // Cleanup
    aclrtFree(aDev); aclrtFreeHost(aHost);
    aclrtFree(bDev); aclrtFreeHost(bHost);
    aclrtFree(cDev); aclrtFreeHost(cHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(0);
    aclFinalize();

    return ok ? 0 : 1;
}
