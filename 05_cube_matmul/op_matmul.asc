/**
 * @file op_matmul.asc
 * @brief [Cube-Only] 算子5: 矩阵乘法 MatMul  C = A × B
 *
 * 类别: 纯Cube核心 — 只调用昇腾NPU的矩阵计算单元(Cube Unit)
 * API:  AscendC::Mmad
 * 内核声明: __global__ __cube__
 *
 * M=64, K=64, N=64 (fp16). 单tile, 无分块循环, 最简Cube示例.
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "../common/data_utils.h"
#include <cstring>

static constexpr uint32_t M = 64, K = 64, N = 64;

class KernelMatmul {
public:
    __aicore__ inline KernelMatmul() = default;
    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR c)
    {
        aGm.SetGlobalBuffer((__gm__ half*)a);
        bGm.SetGlobalBuffer((__gm__ half*)b);
        cGm.SetGlobalBuffer((__gm__ half*)c);
    }

    __aicore__ inline void Process()
    {
        // L1 地址: A区0-128KB, B区128-256KB, C区256-384KB
        constexpr uint64_t a1Off=0, a2Off=0, b1Off=128*1024, b2Off=128*1024, cOff=256*1024;

        AscendC::LocalTensor<half> a1(AscendC::TPosition::A1, a1Off, M*K);
        AscendC::LocalTensor<half> a2(AscendC::TPosition::A2, a2Off, M*K);
        AscendC::LocalTensor<half> b1(AscendC::TPosition::B1, b1Off, K*N);
        AscendC::LocalTensor<half> b2(AscendC::TPosition::B2, b2Off, K*N);
        AscendC::LocalTensor<float> c32(AscendC::TPosition::CO1, cOff, M*N);

        // GM→L1 (Nd2Nz 格式转换)
        NdCopy(a1, aGm, M, K);
        NdCopy(b1, bGm, K, N);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        // L1→L0 (A2/B2是Cube指令直接操作的缓冲区)
        LoadAB(a1, a2, M, K, false);
        LoadAB(b1, b2, K, N, true);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

        // Cube计算
        AscendC::MmadParams mp;
        mp.m = M; mp.n = N; mp.k = K;
        mp.cmatrixInitVal = true;
        AscendC::Mmad(c32, a2, b2, mp);
        AscendC::SetFlag<AscendC::HardEvent::M_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_MTE3>(EVENT_ID0);

        // L0→GM (Fixpipe: float→half量化+搬出)
        AscendC::FixpipeParamsV2 fp;
        fp.nSize = N; fp.mSize = M;
        fp.srcStride = M;
        fp.dstStride = N;
        fp.quantPre = QuantMode_t::F322F16;
        fp.ndNum = 1;
        AscendC::Fixpipe(cGm, c32, fp);
    }

private:
    __aicore__ inline void NdCopy(AscendC::LocalTensor<half>& t, AscendC::GlobalTensor<half>& g, uint32_t r, uint32_t c)
    {
        AscendC::Nd2NzParams p;
        p.ndNum = 1; p.nValue = r; p.dValue = c;
        p.srcNdMatrixStride = 0; p.srcDValue = c;
        p.dstNzC0Stride = r; p.dstNzNStride = 1; p.dstNzMatrixStride = 0;
        AscendC::DataCopy(t, g, p);
    }
    __aicore__ inline void LoadAB(AscendC::LocalTensor<half>& s, AscendC::LocalTensor<half>& d, uint32_t m, uint32_t k, bool transp)
    {
        AscendC::LoadData2DParamsV2 p;
        p.mStep = AscendC::DivCeil(transp ? k : m, 16);
        p.kStep = AscendC::DivCeil((transp ? m : k) * sizeof(half), 32);
        p.srcStride = AscendC::DivCeil(transp ? k : m, 16);
        p.dstStride = AscendC::DivCeil(transp ? m : k, 16);
        p.ifTranspose = transp;
        AscendC::LoadData(d, s, p);
    }
    AscendC::GlobalTensor<half> aGm, bGm, cGm;
};

extern "C" __global__ __cube__ void matmul_kernel(GM_ADDR a, GM_ADDR b, GM_ADDR c)
{
    AscendC::InitSocState();
    KernelMatmul op;
    op.Init(a, b, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int main()
{
    size_t sA = M*K*sizeof(half), sB = K*N*sizeof(half), sC = M*N*sizeof(half);
    size_t sF = M*N*sizeof(float);
    aclInit(nullptr); aclrtSetDevice(0);
    aclrtStream st; aclrtCreateStream(&st);

    float *aF,*bF,*cF,*golden; half *aH,*bH,*cH; uint8_t *dA = nullptr, *dB = nullptr, *dC = nullptr;
    aclrtMallocHost((void**)&aF, M*K*sizeof(float));
    aclrtMallocHost((void**)&bF, K*N*sizeof(float));
    aclrtMallocHost((void**)&cF, sF);
    aclrtMallocHost((void**)&golden, sF);
    aclrtMallocHost((void**)&aH, sA);
    aclrtMallocHost((void**)&bH, sB);
    aclrtMallocHost((void**)&cH, sC);
    aclrtMalloc((void**)&dA,sA,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dB,sB,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dC,sC,ACL_MEM_MALLOC_HUGE_FIRST);

    size_t fs;
    ReadFile("../data/input_matmul_a.bin", fs, aF, M*K*sizeof(float));
    ReadFile("../data/input_matmul_b.bin", fs, bF, K*N*sizeof(float));
    for (uint32_t i=0;i<M*K;i++) aH[i]=(half)aF[i];
    for (uint32_t i=0;i<K*N;i++) bH[i]=(half)bF[i];
    aclrtMemcpy(dA,sA,aH,sA,ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(dB,sB,bH,sB,ACL_MEMCPY_HOST_TO_DEVICE);

    matmul_kernel<<<1,nullptr,st>>>(dA,dB,dC);
    aclrtSynchronizeStream(st);
    double t0=GetTimeUs();
    matmul_kernel<<<1,nullptr,st>>>(dA,dB,dC);
    aclrtSynchronizeStream(st);
    double t1=GetTimeUs();

    aclrtMemcpy(cH,sC,dC,sC,ACL_MEMCPY_DEVICE_TO_HOST);
    for (uint32_t i=0;i<M*N;i++) cF[i]=(float)cH[i];

    INFO_LOG("========== [Cube-Only] MatMul %ux%ux%u ==========", M, K, N);
    INFO_LOG("Kernel time: %.2f us", t1-t0);

    memset(golden,0,sF);
    for (uint32_t mi=0;mi<M;mi++)
        for (uint32_t ki=0;ki<K;ki++)
            for (uint32_t ni=0;ni<N;ni++)
                golden[mi*N+ni] += aF[mi*K+ki]*bF[ki*N+ni];
    bool ok = VerifyResult(cF, golden, M*N, 5e-2f, 1e-3f);

    aclrtFreeHost(golden);
    aclrtFree(dA); aclrtFreeHost(aF); aclrtFreeHost(aH);
    aclrtFree(dB); aclrtFreeHost(bF); aclrtFreeHost(bH);
    aclrtFree(dC); aclrtFreeHost(cF); aclrtFreeHost(cH);
    aclrtDestroyStream(st); aclrtResetDevice(0); aclFinalize();
    return ok ? 0 : 1;
}
