/**
 * @file op_matmul_bias.asc
 * @brief [Cube-Only] 算子6: 矩阵乘(转置B)  C = A × B^T
 *
 * 类别: 纯Cube核心 — B矩阵在搬运阶段转置, Cube直接计算
 * 
 * B原始维度[N×K], 在LoadDataB时转置为[K×N]送入Cube.
 * M=64, K=64, N=64 (fp16). 单tile.
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "../common/data_utils.h"

static constexpr uint32_t M = 64, K = 64, N = 64;

class KernelMatmulTransB {
public:
    __aicore__ inline KernelMatmulTransB() = default;
    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR c)
    {
        aGm.SetGlobalBuffer((__gm__ half*)a);
        // B在GM中为[N×K] (64行64列), 搬运时转置为[K×N]
        bGm.SetGlobalBuffer((__gm__ half*)b);
        cGm.SetGlobalBuffer((__gm__ half*)c);
    }

    __aicore__ inline void Process()
    {
        constexpr uint64_t a1Off=0, a2Off=0, b1Off=128*1024, b2Off=128*1024, cOff=256*1024;

        AscendC::LocalTensor<half> a1(AscendC::TPosition::A1, a1Off, M*K);
        AscendC::LocalTensor<half> a2(AscendC::TPosition::A2, a2Off, M*K);
        AscendC::LocalTensor<half> b1(AscendC::TPosition::B1, b1Off, N*K);
        AscendC::LocalTensor<half> b2(AscendC::TPosition::B2, b2Off, K*N);
        AscendC::LocalTensor<float> c32(AscendC::TPosition::CO1, cOff, M*N);

        // A: Nd2Nz普通搬运
        AscendC::Nd2NzParams pA;
        pA.ndNum=1; pA.nValue=M; pA.dValue=K;
        pA.srcNdMatrixStride=0; pA.srcDValue=K;
        pA.dstNzC0Stride=M; pA.dstNzNStride=1; pA.dstNzMatrixStride=0;
        AscendC::DataCopy(a1, aGm, pA);

        // B: 从[N×K]搬运, Nd2Nz时指定nValue=N, dValue=K
        AscendC::Nd2NzParams pB;
        pB.ndNum=1; pB.nValue=N; pB.dValue=K;
        pB.srcNdMatrixStride=0; pB.srcDValue=K;
        pB.dstNzC0Stride=N; pB.dstNzNStride=1; pB.dstNzMatrixStride=0;
        AscendC::DataCopy(b1, bGm, pB);

        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        // LoadData: A正常, B转置
        AscendC::LoadData2DParamsV2 ldA;
        ldA.mStep=AscendC::DivCeil(M,16); ldA.kStep=AscendC::DivCeil(K*sizeof(half),32);
        ldA.srcStride=AscendC::DivCeil(M,16); ldA.dstStride=AscendC::DivCeil(M,16);
        ldA.ifTranspose=false;
        AscendC::LoadData(a2, a1, ldA);

        // B: L1中存为[N×K], LoadData转置→L0中为[K×N]
        AscendC::LoadData2DParamsV2 ldB;
        ldB.mStep=AscendC::DivCeil(N,16); ldB.kStep=AscendC::DivCeil(K*sizeof(half),32);
        ldB.srcStride=AscendC::DivCeil(N,16); ldB.dstStride=AscendC::DivCeil(K,16);
        ldB.ifTranspose=true;
        AscendC::LoadData(b2, b1, ldB);

        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

        AscendC::MmadParams mp;
        mp.m=M; mp.n=N; mp.k=K; mp.cmatrixInitVal=true;
        AscendC::Mmad(c32, a2, b2, mp);
        AscendC::SetFlag<AscendC::HardEvent::M_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_MTE3>(EVENT_ID0);

        AscendC::FixpipeParamsV2 fp;
        fp.nSize=N; fp.mSize=M; fp.srcStride=M; fp.dstStride=N;
        fp.quantPre=QuantMode_t::F322F16; fp.ndNum=1;
        AscendC::Fixpipe(cGm, c32, fp);
    }
private:
    AscendC::GlobalTensor<half> aGm, bGm, cGm;
};

extern "C" __global__ __cube__ void matmul_transb_kernel(GM_ADDR a, GM_ADDR b, GM_ADDR c)
{
    AscendC::InitSocState();
    KernelMatmulTransB op;
    op.Init(a, b, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int main()
{
    size_t sA=M*K*sizeof(half), sB=N*K*sizeof(half), sC=M*N*sizeof(half), sF=M*N*sizeof(float);
    aclInit(nullptr); aclrtSetDevice(0);
    aclrtStream st; aclrtCreateStream(&st);

    float *aF,*bF,*cF,*golden; half *aH,*bH,*cH; void *dA,*dB,*dC;
    aclrtMallocHost((void**)&aF, M*K*sizeof(float));
    aclrtMallocHost((void**)&bF, N*K*sizeof(float));
    aclrtMallocHost((void**)&cF, sF);
    aclrtMallocHost((void**)&golden, sF);
    aclrtMallocHost((void**)&aH, sA);
    aclrtMallocHost((void**)&bH, sB);
    aclrtMallocHost((void**)&cH, sC);
    aclrtMalloc(&dA,sA,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&dB,sB,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&dC,sC,ACL_MEM_MALLOC_HUGE_FIRST);

    size_t fs;
    ReadFile("../data/input_matmul_a.bin", fs, aF, M*K*sizeof(float));
    ReadFile("../data/input_matmul_b.bin", fs, bF, N*K*sizeof(float));
    for (uint32_t i=0;i<M*K;i++) aH[i]=(half)aF[i];
    for (uint32_t i=0;i<N*K;i++) bH[i]=(half)bF[i];
    aclrtMemcpy(dA,sA,aH,sA,ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(dB,sB,bH,sB,ACL_MEMCPY_HOST_TO_DEVICE);

    matmul_transb_kernel<<<1,nullptr,st>>>(dA,dB,dC);
    aclrtSynchronizeStream(st);
    double t0=GetTimeUs();
    matmul_transb_kernel<<<1,nullptr,st>>>(dA,dB,dC);
    aclrtSynchronizeStream(st);
    double t1=GetTimeUs();

    aclrtMemcpy(cH,sC,dC,sC,ACL_MEMCPY_DEVICE_TO_HOST);
    for (uint32_t i=0;i<M*N;i++) cF[i]=(float)cH[i];

    INFO_LOG("========== [Cube-Only] MatMulTransB %ux%ux%u ==========", M, K, N);
    INFO_LOG("Kernel time: %.2f us", t1-t0);

    memset(golden,0,sF);
    for (uint32_t mi=0;mi<M;mi++)
        for (uint32_t ki=0;ki<K;ki++)
            for (uint32_t ni=0;ni<N;ni++)
                golden[mi*N+ni] += aF[mi*K+ki]*bF[ni*K+ki]; // B^T: b[ni][ki]
    bool ok = VerifyResult(cF, golden, M*N, 5e-2f, 1e-3f);

    aclrtFreeHost(golden);
    aclrtFree(dA); aclrtFreeHost(aF); aclrtFreeHost(aH);
    aclrtFree(dB); aclrtFreeHost(bF); aclrtFreeHost(bH);
    aclrtFree(dC); aclrtFreeHost(cF); aclrtFreeHost(cH);
    aclrtDestroyStream(st); aclrtResetDevice(0); aclFinalize();
    return ok ? 0 : 1;
}
