/**
 * @file op_matmul_large.asc
 * @brief [Cube-Only] 算子7: 大矩阵乘(分tile) MatMul  C[MxN] = A[MxK] x B[KxN]
 *
 * 类别: 纯Cube核心 — K方向循环累加分tile演示
 * M=128, K=128, N=128 (fp16). baseT=64, K方向2个tile循环累加.
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "../common/data_utils.h"
#include <cstring>

static constexpr uint32_t M = 128, K = 128, N = 128;
static constexpr uint32_t BZ = 64;

class KernelMatmulLarge {
public:
    __aicore__ inline KernelMatmulLarge() = default;
    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR c)
    {
        aGm.SetGlobalBuffer((__gm__ half*)a);
        bGm.SetGlobalBuffer((__gm__ half*)b);
        cGm.SetGlobalBuffer((__gm__ half*)c);
    }

    __aicore__ inline void Process()
    {
        constexpr uint64_t a1Off=0, a2Off=0, b1Off=128*1024, b2Off=128*1024, cOff=256*1024;
        AscendC::LocalTensor<half> a1(AscendC::TPosition::A1, a1Off, BZ*BZ);
        AscendC::LocalTensor<half> a2(AscendC::TPosition::A2, a2Off, BZ*BZ);
        AscendC::LocalTensor<half> b1(AscendC::TPosition::B1, b1Off, BZ*BZ);
        AscendC::LocalTensor<half> b2(AscendC::TPosition::B2, b2Off, BZ*BZ);
        AscendC::LocalTensor<float> c32(AscendC::TPosition::CO1, cOff, BZ*BZ);

        constexpr uint32_t mL=2, nL=2, kL=2; // 128/64 = 2

        for (uint32_t mi=0; mi<mL; mi++) {
            for (uint32_t ni=0; ni<nL; ni++) {
                for (uint32_t ki=0; ki<kL; ki++) {
                    // 1. 搬运 A、B 的 tile 到 A1/B1
                    NdTile(a1, aGm, mi, ki, BZ, BZ, K);
                    NdTile(b1, bGm, ki, ni, BZ, BZ, N);
                    AscendC::Barrier();   // 等待搬入完成

                    // 2. 将 A1/B1 数据重排为 A2/B2 (矩阵乘专用格式)
                    LoadAB(a1, a2, BZ, BZ, false);
                    LoadAB(b1, b2, BZ, BZ, true);
                    AscendC::Barrier();   // 等待格式转换完成

                    // 3. 矩阵乘累加
                    AscendC::MmadParams mp;
                    mp.m=BZ; mp.n=BZ; mp.k=BZ; mp.cmatrixInitVal=(ki==0);
                    AscendC::Mmad(c32, a2, b2, mp);
                    AscendC::Barrier();   // 等待乘法完成
                }
                // 4. 将 CO1 中的 float 结果转为 fp16 并写回 Global
                AscendC::FixpipeParamsV220 fp;
                fp.nSize=BZ; fp.mSize=BZ; fp.srcStride=BZ; fp.dstStride=N;
                fp.quantPre=QuantMode_t::F322F16; fp.ndNum=1;
                AscendC::Fixpipe(cGm[mi*BZ*N + ni*BZ], c32, fp);
                AscendC::Barrier();   // 等待写回完成
            }
        }
    }

private:
    // NdTile: 从 Global 搬移一个二维 tile 到 A1/B1
    __aicore__ inline void NdTile(AscendC::LocalTensor<half>& t, AscendC::GlobalTensor<half>& g,
                                   uint32_t rOff, uint32_t cOff, uint32_t r, uint32_t c, uint32_t ld) {
        AscendC::Nd2NzParams p;
        p.ndNum=1; p.nValue=r; p.dValue=c;
        p.srcNdMatrixStride=0; p.srcDValue=ld;
        p.dstNzC0Stride=r; p.dstNzNStride=1; p.dstNzMatrixStride=0;
        AscendC::DataCopy(t, g[rOff*r*ld + cOff*c], p);
    }

    // LoadAB: 将 A1/B1 数据加载为矩阵乘专用格式
    __aicore__ inline void LoadAB(AscendC::LocalTensor<half>& s, AscendC::LocalTensor<half>& d,
                                   uint32_t m, uint32_t k, bool tp) {
        AscendC::LoadData2DParamsV2 p;
        p.mStep=AscendC::DivCeil(tp?k:m,16);
        p.kStep=AscendC::DivCeil((tp?m:k)*sizeof(half),32);
        p.srcStride=AscendC::DivCeil(tp?k:m,16);
        p.dstStride=AscendC::DivCeil(tp?m:k,16);
        p.ifTranspose=tp;
        AscendC::LoadData(d, s, p);
    }

    AscendC::GlobalTensor<half> aGm, bGm, cGm;
};

extern "C" __global__ __cube__ void matmul_large_kernel(GM_ADDR a, GM_ADDR b, GM_ADDR c)
{
    AscendC::InitSocState();
    KernelMatmulLarge op;
    op.Init(a, b, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();   // 最终同步
}

int main()
{
    size_t sA=M*K*sizeof(half), sB=K*N*sizeof(half), sC=M*N*sizeof(half), sF=M*N*sizeof(float);
    aclInit(nullptr); aclrtSetDevice(0);
    aclrtStream st; aclrtCreateStream(&st);

    float *aF,*bF,*cF,*golden; half *aH,*bH,*cH; uint8_t *dA = nullptr, *dB = nullptr, *dC = nullptr;
    aclrtMallocHost((void**)&aF, M*K*sizeof(float));
    aclrtMallocHost((void**)&bF, K*N*sizeof(float));
    aclrtMallocHost((void**)&cF, sF);
    aclrtMallocHost((void**)&golden, sF);
    aclrtMallocHost((void**)&aH, sA);
    aclrtMallocHost((void**)&bH, sB);
    aclrtMallocHost((void**)&cH, sC);
    aclrtMalloc((void**)&dA,sA,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dB,sB,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dC,sC,ACL_MEM_MALLOC_HUGE_FIRST);

    size_t fs;
    ReadFile("../data/input_matmul_a.bin", fs, aF, M*K*sizeof(float));
    ReadFile("../data/input_matmul_b.bin", fs, bF, K*N*sizeof(float));
    for (uint32_t i=0;i<M*K;i++) aH[i]=(half)aF[i];
    for (uint32_t i=0;i<K*N;i++) bH[i]=(half)bF[i];
    aclrtMemcpy(dA,sA,aH,sA,ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(dB,sB,bH,sB,ACL_MEMCPY_HOST_TO_DEVICE);

    matmul_large_kernel<<<1,nullptr,st>>>(dA,dB,dC);
    aclrtSynchronizeStream(st);
    double t0=GetTimeUs();
    matmul_large_kernel<<<1,nullptr,st>>>(dA,dB,dC);
    aclrtSynchronizeStream(st);
    double t1=GetTimeUs();

    aclrtMemcpy(cH,sC,dC,sC,ACL_MEMCPY_DEVICE_TO_HOST);
    for (uint32_t i=0;i<M*N;i++) cF[i]=(float)cH[i];

    INFO_LOG("========== [Cube-Only] MatMulLarge %ux%ux%u ==========", M, K, N);
    INFO_LOG("Kernel time: %.2f us", t1-t0);
    double flops=2.0*M*K*N;
    INFO_LOG("TFLOPS: %.4f", flops/((t1-t0)*1e-6)/1e12);

    // 用 memset 替代原代码的循环计算 golden（原代码 memset 使用有误）
    // 计算 golden 矩阵
    for (uint32_t mi=0; mi<M; mi++)
        for (uint32_t ki=0; ki<K; ki++)
            for (uint32_t ni=0; ni<N; ni++)
                golden[mi*N+ni] += aF[mi*K+ki] * bF[ki*N+ni];
    bool ok = VerifyResult(cF, golden, M*N, 5e-2f, 1e-3f);

    aclrtFreeHost(golden);
    aclrtFree(dA); aclrtFreeHost(aF); aclrtFreeHost(aH);
    aclrtFree(dB); aclrtFreeHost(bF); aclrtFreeHost(bH);
    aclrtFree(dC); aclrtFreeHost(cF); aclrtFreeHost(cH);
    aclrtDestroyStream(st); aclrtResetDevice(0); aclFinalize();
    return ok ? 0 : 1;
}