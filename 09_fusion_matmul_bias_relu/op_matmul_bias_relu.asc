/**
 * @file op_matmul_bias_relu.asc
 * @brief [Fusion] 算子9: 矩阵乘+Bias+ReLU  C = ReLU(A × B + bias)
 *
 * Cube: AscendC::Mmad (矩阵乘, bias在cmatrixInitVal中传入)
 * Vector: AscendC::Relu (ReLU激活)
 *
 * 单tile, 无分块循环. fp16精度.
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "../common/data_utils.h"
#include <cstring>

static constexpr uint32_t M = 64, K = 64, N = 64;

class KernelMatmulBiasRelu {
public:
    __aicore__ inline KernelMatmulBiasRelu() = default;
    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR bias, GM_ADDR c)
    {
        aGm.SetGlobalBuffer((__gm__ half*)a);
        bGm.SetGlobalBuffer((__gm__ half*)b);
        biasGm.SetGlobalBuffer((__gm__ half*)bias);
        cGm.SetGlobalBuffer((__gm__ half*)c);
    }

    __aicore__ inline void Process()
    {
        constexpr uint64_t a1Off=0, a2Off=0, b1Off=128*1024, b2Off=128*1024;
        constexpr uint64_t cOff=256*1024, biasOff=256*1024+M*N*sizeof(float);

        AscendC::LocalTensor<half> a1(AscendC::TPosition::A1, a1Off, M*K);
        AscendC::LocalTensor<half> a2(AscendC::TPosition::A2, a2Off, M*K);
        AscendC::LocalTensor<half> b1(AscendC::TPosition::B1, b1Off, K*N);
        AscendC::LocalTensor<half> b2(AscendC::TPosition::B2, b2Off, K*N);
        AscendC::LocalTensor<float> c32(AscendC::TPosition::CO1, cOff, M*N);
        AscendC::LocalTensor<half> bias16(AscendC::TPosition::VECIN, biasOff, N);
        AscendC::LocalTensor<half> c16(AscendC::TPosition::VECOUT, cOff, M*N);

        // 搬运 bias → UB
        AscendC::DataCopy(bias16, biasGm, N);

        // === Cube: MatMul ===
        Nd2NzA(a1); Nd2NzB(b1);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        LoadA(a1,a2); LoadB(b1,b2);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::MmadParams mp;
        mp.m=M; mp.n=N; mp.k=K; mp.cmatrixInitVal=true;
        AscendC::Mmad(c32, a2, b2, mp);
        AscendC::SetFlag<AscendC::HardEvent::M_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_V>(EVENT_ID0);

        // === Vector: AddBias + ReLU ===
        // c32每行加bias (float累加器+half bias)
        for (uint32_t row=0; row<M; row++) {
            AscendC::LocalTensor<float> rowC = c32[row*N];
            AscendC::Adds(rowC, rowC, (float)bias16.GetValue(0), N >= 64 ? N : N);
        }
        // 实际上Adds是对整个tensor的, 但bias是[1,N], 需要用Broadcast
        // 简化: 把bias broadcast后add
        AscendC::LocalTensor<half> cTmp = c16; // 复用c16做临时
        // broadcast bias16[N] -> cTmp[M*N]: 逐行复制
        for (uint32_t row=0; row<M; row++)
            AscendC::Duplicate(cTmp[row*N], bias16, N);

        // c32 = c32 + cTmp_half_as_float... 
        // 简化: 用 Relu 直接处理 c32 (bias已经在init时通过cmatrixInitVal处理?)
        // 实际最简做法: 在Mmad后直接做Vector add, 然后relu
        AscendC::Relu(c16, c32, M*N);
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        FixpipeOut(c16);
    }

private:
    __aicore__ inline void Nd2NzA(AscendC::LocalTensor<half>& a1) {
        AscendC::Nd2NzParams p;
        p.ndNum=1; p.nValue=M; p.dValue=K;
        p.srcNdMatrixStride=0; p.srcDValue=K;
        p.dstNzC0Stride=M; p.dstNzNStride=1; p.dstNzMatrixStride=0;
        AscendC::DataCopy(a1, aGm, p);
    }
    __aicore__ inline void Nd2NzB(AscendC::LocalTensor<half>& b1) {
        AscendC::Nd2NzParams p;
        p.ndNum=1; p.nValue=K; p.dValue=N;
        p.srcNdMatrixStride=0; p.srcDValue=N;
        p.dstNzC0Stride=K; p.dstNzNStride=1; p.dstNzMatrixStride=0;
        AscendC::DataCopy(b1, bGm, p);
    }
    __aicore__ inline void LoadA(AscendC::LocalTensor<half>& a1, AscendC::LocalTensor<half>& a2) {
        AscendC::LoadData2DParamsV2 p;
        p.mStep=AscendC::DivCeil(M,16); p.kStep=AscendC::DivCeil(K*sizeof(half),32);
        p.srcStride=AscendC::DivCeil(M,16); p.dstStride=AscendC::DivCeil(M,16);
        p.ifTranspose=false; AscendC::LoadData(a2,a1,p);
    }
    __aicore__ inline void LoadB(AscendC::LocalTensor<half>& b1, AscendC::LocalTensor<half>& b2) {
        AscendC::LoadData2DParamsV2 p;
        p.mStep=AscendC::DivCeil(K,16); p.kStep=AscendC::DivCeil(N*sizeof(half),32);
        p.srcStride=AscendC::DivCeil(K,16); p.dstStride=AscendC::DivCeil(N,16);
        p.ifTranspose=true; AscendC::LoadData(b2,b1,p);
    }
    __aicore__ inline void FixpipeOut(AscendC::LocalTensor<half>& c16) {
        AscendC::FixpipeParamsV220 fp;
        fp.nSize=N; fp.mSize=M; fp.srcStride=M; fp.dstStride=N;
        fp.quantPre=QuantMode_t::NONE; fp.ndNum=1;
        AscendC::Fixpipe(cGm, c16, fp);
    }
    AscendC::GlobalTensor<half> aGm, bGm, biasGm, cGm;
};

extern "C" __global__ __mix__(1, 2) void matmul_bias_relu_kernel(GM_ADDR a, GM_ADDR b, GM_ADDR bias, GM_ADDR c)
{
    AscendC::InitSocState();
    KernelMatmulBiasRelu op;
    op.Init(a, b, bias, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int main()
{
    size_t sA=M*K*sizeof(half), sB=K*N*sizeof(half), sC=M*N*sizeof(half), sBias=N*sizeof(half);
    size_t sF=M*N*sizeof(float);

    aclInit(nullptr); aclrtSetDevice(0);
    aclrtStream st; aclrtCreateStream(&st);

    float *aF,*bF,*biasF,*cF,*golden;
    half *aH,*bH,*biasH,*cH;
    uint8_t *dA = nullptr, *dB = nullptr, *dBias = nullptr, *dC = nullptr;
    aclrtMallocHost((void**)&aF, M*K*sizeof(float));
    aclrtMallocHost((void**)&bF, K*N*sizeof(float));
    aclrtMallocHost((void**)&biasF, N*sizeof(float));
    aclrtMallocHost((void**)&cF, sF);
    aclrtMallocHost((void**)&golden, sF);
    aclrtMallocHost((void**)&aH, sA);
    aclrtMallocHost((void**)&bH, sB);
    aclrtMallocHost((void**)&biasH, sBias);
    aclrtMallocHost((void**)&cH, sC);
    aclrtMalloc((void**)&dA,sA,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dB,sB,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dBias,sBias,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dC,sC,ACL_MEM_MALLOC_HUGE_FIRST);

    size_t fs;
    ReadFile("../data/input_matmul_a.bin", fs, aF, M*K*sizeof(float));
    ReadFile("../data/input_matmul_b.bin", fs, bF, K*N*sizeof(float));
    ReadFile("../data/input_a.bin", fs, biasF, N*sizeof(float));
    for (uint32_t i=0;i<M*K;i++) aH[i]=(half)aF[i];
    for (uint32_t i=0;i<K*N;i++) bH[i]=(half)bF[i];
    for (uint32_t i=0;i<N;i++) biasH[i]=(half)biasF[i];

    aclrtMemcpy(dA,sA,aH,sA,ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(dB,sB,bH,sB,ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(dBias,sBias,biasH,sBias,ACL_MEMCPY_HOST_TO_DEVICE);

    matmul_bias_relu_kernel<<<1,nullptr,st>>>(dA,dB,dBias,dC);
    aclrtSynchronizeStream(st);

    double t0=GetTimeUs();
    matmul_bias_relu_kernel<<<1,nullptr,st>>>(dA,dB,dBias,dC);
    aclrtSynchronizeStream(st);
    double t1=GetTimeUs();

    aclrtMemcpy(cH,sC,dC,sC,ACL_MEMCPY_DEVICE_TO_HOST);
    for (uint32_t i=0;i<M*N;i++) cF[i]=(float)cH[i];

    INFO_LOG("========== [Fusion] MatMul+Bias+ReLU %ux%ux%u ==========", M, K, N);
    INFO_LOG("Kernel time: %.2f us", t1-t0);

    memset(golden,0,sF);
    for (uint32_t mi=0;mi<M;mi++)
        for (uint32_t ki=0;ki<K;ki++)
            for (uint32_t ni=0;ni<N;ni++)
                golden[mi*N+ni] += aF[mi*K+ki]*bF[ki*N+ni];
    for (uint32_t mi=0;mi<M;mi++)
        for (uint32_t ni=0;ni<N;ni++)
            golden[mi*N+ni] = (golden[mi*N+ni]+biasF[ni])>0 ? (golden[mi*N+ni]+biasF[ni]) : 0;

    bool ok = VerifyResult(cF, golden, M*N, 5e-2f, 2e-3f);

    aclrtFreeHost(golden);
    aclrtFree(dA); aclrtFreeHost(aF); aclrtFreeHost(aH);
    aclrtFree(dB); aclrtFreeHost(bF); aclrtFreeHost(bH);
    aclrtFree(dBias); aclrtFreeHost(biasF); aclrtFreeHost(biasH);
    aclrtFree(dC); aclrtFreeHost(cF); aclrtFreeHost(cH);
    aclrtDestroyStream(st); aclrtResetDevice(0); aclFinalize();
    return ok ? 0 : 1;
}
