/**
 * @file op_matmul_add.asc
 * @brief [Fusion] 算子10: 矩阵乘+残差加 Y = A × B + residual
 *
 * Cube: AscendC::Mmad  — 矩阵乘
 * Vector: AscendC::Add — 残差加法 (常用于Transformer的残差连接)
 *
 * 单tile 64x64, fp16.
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "../common/data_utils.h"
#include <cstring>

static constexpr uint32_t M = 64, K = 64, N = 64;

class KernelMatmulAdd {
public:
    __aicore__ inline KernelMatmulAdd() = default;
    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR res, GM_ADDR y)
    {
        aGm.SetGlobalBuffer((__gm__ half*)a);
        bGm.SetGlobalBuffer((__gm__ half*)b);
        resGm.SetGlobalBuffer((__gm__ half*)res);
        yGm.SetGlobalBuffer((__gm__ half*)y);
    }

    __aicore__ inline void Process()
    {
        constexpr uint64_t a1Off=0, a2Off=0, b1Off=128*1024, b2Off=128*1024;
        constexpr uint64_t cOff=256*1024, resOff=256*1024+M*N*sizeof(float);

        AscendC::LocalTensor<half> a1(AscendC::TPosition::A1, a1Off, M*K);
        AscendC::LocalTensor<half> a2(AscendC::TPosition::A2, a2Off, M*K);
        AscendC::LocalTensor<half> b1(AscendC::TPosition::B1, b1Off, K*N);
        AscendC::LocalTensor<half> b2(AscendC::TPosition::B2, b2Off, K*N);
        AscendC::LocalTensor<float> c32(AscendC::TPosition::CO1, cOff, M*N);
        AscendC::LocalTensor<half> res16(AscendC::TPosition::VECIN, resOff, M*N);
        AscendC::LocalTensor<half> y16(AscendC::TPosition::VECOUT, cOff, M*N);

        // 搬运residual
        AscendC::DataCopy(res16, resGm, M*N);

        // === Cube: MatMul ===
        Nd2Nz(a1, aGm, M, K);
        Nd2Nz(b1, bGm, K, N);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        LoadAB(a1,a2,M,K,false);
        LoadAB(b1,b2,K,N,true);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::MmadParams mp;
        mp.m=M; mp.n=N; mp.k=K; mp.cmatrixInitVal=true;
        AscendC::Mmad(c32, a2, b2, mp);
        AscendC::SetFlag<AscendC::HardEvent::M_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_V>(EVENT_ID0);

        // === Vector: Add residual ===
        AscendC::Add(y16, c32, res16, M*N);
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        Fixpipe(y16);
    }

private:
    __aicore__ inline void Nd2Nz(AscendC::LocalTensor<half>& t, AscendC::GlobalTensor<half>& g, uint32_t m, uint32_t k) {
        AscendC::Nd2NzParams p;
        p.ndNum=1; p.nValue=m; p.dValue=k;
        p.srcNdMatrixStride=0; p.srcDValue=k;
        p.dstNzC0Stride=m; p.dstNzNStride=1; p.dstNzMatrixStride=0;
        AscendC::DataCopy(t, g, p);
    }
    __aicore__ inline void LoadAB(AscendC::LocalTensor<half>& s, AscendC::LocalTensor<half>& d, uint32_t m, uint32_t k, bool transp) {
        AscendC::LoadData2DParamsV2 p;
        p.mStep=AscendC::DivCeil(transp?k:m,16);
        p.kStep=AscendC::DivCeil((transp?m:k)*sizeof(half),32);
        p.srcStride=AscendC::DivCeil(transp?k:m,16);
        p.dstStride=AscendC::DivCeil(transp?m:k,16);
        p.ifTranspose=transp;
        AscendC::LoadData(d,s,p);
    }
    __aicore__ inline void Fixpipe(AscendC::LocalTensor<half>& y) {
        AscendC::FixpipeParamsV2 fp;
        fp.nSize=N; fp.mSize=M; fp.srcStride=M; fp.dstStride=N;
        fp.quantPre=QuantMode_t::NONE; fp.ndNum=1;
        AscendC::Fixpipe(yGm, y, fp);
    }
    AscendC::GlobalTensor<half> aGm, bGm, resGm, yGm;
};

extern "C" __global__ __cube_vec__ void matmul_add_kernel(GM_ADDR a, GM_ADDR b, GM_ADDR res, GM_ADDR y)
{
    AscendC::InitSocState();
    KernelMatmulAdd op;
    op.Init(a, b, res, y);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int main()
{
    size_t sA=M*K*sizeof(half), sB=K*N*sizeof(half), sC=M*N*sizeof(half);
    size_t sF=M*N*sizeof(float);

    aclInit(nullptr); aclrtSetDevice(0);
    aclrtStream st; aclrtCreateStream(&st);

    float *aF,*bF,*rF,*yF,*golden;
    half *aH,*bH,*rH,*yH;
    uint8_t *dA = nullptr, *dB = nullptr, *dR = nullptr, *dY = nullptr;
    aclrtMallocHost((void**)&aF, M*K*sizeof(float));
    aclrtMallocHost((void**)&bF, K*N*sizeof(float));
    aclrtMallocHost((void**)&rF, sF);
    aclrtMallocHost((void**)&yF, sF);
    aclrtMallocHost((void**)&golden, sF);
    aclrtMallocHost((void**)&aH, sA);
    aclrtMallocHost((void**)&bH, sB);
    aclrtMallocHost((void**)&rH, sC);
    aclrtMallocHost((void**)&yH, sC);
    aclrtMalloc((void**)&dA,sA,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dB,sB,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dR,sC,ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dY,sC,ACL_MEM_MALLOC_HUGE_FIRST);

    size_t fs;
    ReadFile("../data/input_matmul_a.bin", fs, aF, M*K*sizeof(float));
    ReadFile("../data/input_matmul_b.bin", fs, bF, K*N*sizeof(float));
    ReadFile("../data/input_a.bin", fs, rF, M*N*sizeof(float));
    for (uint32_t i=0;i<M*K;i++) aH[i]=(half)aF[i];
    for (uint32_t i=0;i<K*N;i++) bH[i]=(half)bF[i];
    for (uint32_t i=0;i<M*N;i++) rH[i]=(half)rF[i];

    aclrtMemcpy(dA,sA,aH,sA,ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(dB,sB,bH,sB,ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(dR,sC,rH,sC,ACL_MEMCPY_HOST_TO_DEVICE);

    matmul_add_kernel<<<1,nullptr,st>>>(dA,dB,dR,dY);
    aclrtSynchronizeStream(st);

    double t0=GetTimeUs();
    matmul_add_kernel<<<1,nullptr,st>>>(dA,dB,dR,dY);
    aclrtSynchronizeStream(st);
    double t1=GetTimeUs();

    aclrtMemcpy(yH,sC,dY,sC,ACL_MEMCPY_DEVICE_TO_HOST);
    for (uint32_t i=0;i<M*N;i++) yF[i]=(float)yH[i];

    INFO_LOG("========== [Fusion] MatMul+Add %ux%ux%u ==========", M, K, N);
    INFO_LOG("Kernel time: %.2f us", t1-t0);

    memset(golden,0,sF);
    for (uint32_t mi=0;mi<M;mi++)
        for (uint32_t ki=0;ki<K;ki++)
            for (uint32_t ni=0;ni<N;ni++)
                golden[mi*N+ni] += aF[mi*K+ki]*bF[ki*N+ni];
    for (uint32_t i=0;i<M*N;i++) golden[i] += rF[i];

    bool ok = VerifyResult(yF, golden, M*N, 5e-2f, 2e-3f);

    aclrtFreeHost(golden);
    aclrtFree(dA); aclrtFreeHost(aF); aclrtFreeHost(aH);
    aclrtFree(dB); aclrtFreeHost(bF); aclrtFreeHost(bH);
    aclrtFree(dR); aclrtFreeHost(rF); aclrtFreeHost(rH);
    aclrtFree(dY); aclrtFreeHost(yF); aclrtFreeHost(yH);
    aclrtDestroyStream(st); aclrtResetDevice(0); aclFinalize();
    return ok ? 0 : 1;
}
